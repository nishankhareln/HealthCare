# =============================================================================
# Samni Labs backend — environment template
# =============================================================================
#
# Copy to `.env` and fill in the real values for your environment. Never
# commit `.env` — it holds production secrets. `.env` is already in
# `.gitignore`. Files loaded by pydantic-settings from this template key
# by `case_sensitive=True`, so the variable names MUST match exactly.
#
# Three classes of values appear here:
#   * SECRET    — rotate if leaked. Must come from AWS Secrets Manager /
#                 Parameter Store in non-dev; never from a file on disk
#                 once the container is deployed.
#   * REQUIRED  — the app refuses to start in staging/production without
#                 this (see `enforce_production_requirements` in
#                 config.py). Dev tolerates empty values.
#   * OPTIONAL  — has a safe default in code. Only override to tune.
#
# In dev you can leave REQUIRED values empty and the app still boots
# against a local Postgres, moto, and a fake JWT — but any endpoint
# that hits AWS will error. In staging/production every REQUIRED
# variable must be set; the guardrails will refuse to boot otherwise
# (e.g. an `-dev` bucket in prod, a `localhost` DSN in prod).
#
# =============================================================================


# -----------------------------------------------------------------------------
# Environment / logging
# -----------------------------------------------------------------------------
# ENVIRONMENT controls strict validation. `dev` allows empty AWS values;
# `staging` and `production` do not. Never set this to `dev` in a
# deployed container — it disables every production guardrail.
ENVIRONMENT=dev

# DEBUG in prod makes logs verbose and, worse, some libraries dump
# request/response payloads that contain PHI. Keep INFO or higher in
# any deployed environment.
LOG_LEVEL=INFO

# Reported by GET /health. Set from CI (commit SHA or release tag).
APP_VERSION=1.0.0


# -----------------------------------------------------------------------------
# AWS core
# -----------------------------------------------------------------------------
# Region for every boto3 client (S3, SQS, SNS, Bedrock, Transcribe,
# Cognito JWKS). Must match where your resources live; cross-region
# S3 reads from Transcribe Medical will fail silently.
AWS_REGION=us-east-1

# AWS credentials — DO NOT set these in a deployed container. Use an
# IAM role attached to the ECS task / EKS service account / EC2
# instance profile. These three lines exist only for local development
# with temporary credentials from `aws sso login`. Leave empty
# otherwise.
#
# SECRET — rotate immediately if committed anywhere.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=


# -----------------------------------------------------------------------------
# S3
# -----------------------------------------------------------------------------
# Bucket holding every piece of PHI: uploaded PDFs, uploaded audio,
# transcripts, and generated PDFs. Must have:
#   * SSE-KMS default encryption
#   * Block Public Access = fully on
#   * Versioning enabled
#   * Object Lock (compliance mode) for audit artifacts
# The boot guardrail refuses to start in non-dev if this ends with
# `-dev`.
S3_BUCKET=samni-phi-documents-dev

# Presigned URL TTL (seconds). Short TTL limits the blast radius of a
# leaked URL. Range: 60–3600. Default 900 (15 minutes) is a good
# balance for mobile upload retries.
S3_PRESIGNED_EXPIRY=900


# -----------------------------------------------------------------------------
# SQS — pipeline work queue
# -----------------------------------------------------------------------------
# REQUIRED in non-dev. Full URL, not ARN:
#   https://sqs.<region>.amazonaws.com/<account>/<queue-name>
# The queue MUST have:
#   * A dead-letter queue (DLQ) attached with maxReceiveCount=3
#   * SSE enabled (KMS key, not SSE-SQS-managed)
#   * VisibilityTimeout >= SQS_VISIBILITY_TIMEOUT here
SQS_QUEUE_URL=

# Long-poll wait time. Max 20s per AWS. Lower = more API calls = more $.
SQS_WAIT_TIME_SECONDS=20

# How long a message stays invisible after a worker picks it up.
# Must exceed the longest pipeline run time with margin. Transcribe
# Medical alone can take minutes for long dictations; 900s (15 min) is
# the default. Raise if your dictations are long.
SQS_VISIBILITY_TIMEOUT=900

# Messages per poll. Keep at 1 so one crash loses one message, not ten.
SQS_MAX_MESSAGES_PER_POLL=1


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# REQUIRED. SECRET (contains password).
#
# Async driver, used by the FastAPI app, worker, and LangGraph
# checkpointer. Scheme MUST be `postgresql+asyncpg://`.
# In non-dev, `sslmode=require` is appended automatically by
# database.py and pipeline.py. Prefer `sslmode=verify-full` with a
# pinned CA bundle in production.
#
# Example (prod):
#   postgresql+asyncpg://samni_app:REDACTED@db.prod.samni.internal:5432/samni?sslmode=verify-full
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/samni_dev

# REQUIRED. SECRET. Used ONLY by Alembic migrations. Sync driver.
# Same credentials and host as DATABASE_URL; only the scheme changes.
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/samni_dev

# Connection pool tuning. Match DB_POOL_SIZE + DB_MAX_OVERFLOW to the
# RDS `max_connections` minus headroom for migrations and the
# checkpointer pool. Default (10 + 5 = 15 per instance) is safe for
# small RDS. A 4-task ECS deployment at default sizing reserves 60
# connections.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# NEVER enable in non-dev. SQLAlchemy echo dumps every SQL statement
# including bound parameters — that's patient data in plaintext logs.
DB_ECHO=false


# -----------------------------------------------------------------------------
# Cognito — authentication
# -----------------------------------------------------------------------------
# REQUIRED in non-dev.
#
# User Pool ID in the form `<region>_<id>`, e.g. `us-east-1_AbCdEfGhI`.
# The app builds the JWKS URL from this and the region; mismatched
# region here = every JWT fails signature check.
COGNITO_USER_POOL_ID=

# App Client ID used as the JWT `aud` (or `client_id`) claim. Tokens
# issued for a different client will be rejected.
COGNITO_APP_CLIENT_ID=

# JWKS cache TTL in seconds. Cognito key rotation is rare but real;
# the default 1h limits exposure after a rotation without hammering
# the JWKS endpoint on every request.
COGNITO_JWKS_CACHE_TTL=3600


# -----------------------------------------------------------------------------
# SNS — caregiver push notifications
# -----------------------------------------------------------------------------
# REQUIRED in non-dev. Full ARN:
#   arn:aws:sns:<region>:<account>:<topic-name>
# The topic MUST be encrypted with the same KMS key as the rest of
# the PHI surface (or a dedicated notifications key with a matching
# policy). Notification bodies deliberately avoid PHI — they carry
# run_id and patient_id only — but even metadata should ride KMS.
SNS_TOPIC_ARN=


# -----------------------------------------------------------------------------
# Bedrock — LLM (Claude)
# -----------------------------------------------------------------------------
# Model used by both the field-mapping node and the critic node.
# Pin to a specific model id rather than a family alias so a Bedrock-
# side version bump cannot silently change extraction behaviour on
# live patients.
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514

# Low temperature for deterministic medical field extraction. 0.0–0.2
# is the normal range; anything higher risks hallucinated values.
BEDROCK_TEMPERATURE=0.1

# Max output tokens per call. 4096 fits the largest single assessment
# mapping response; raise only if the critic starts truncating.
BEDROCK_MAX_TOKENS=4096

# Per-call timeout in seconds. Bedrock Claude calls occasionally
# take 30–40s on long inputs; 60s leaves headroom without extending
# SQS visibility budget indefinitely.
BEDROCK_TIMEOUT_SECONDS=60


# -----------------------------------------------------------------------------
# Transcribe Medical
# -----------------------------------------------------------------------------
# Language for all dictations. en-US is the only setting tested with
# the current prompt templates. PRIMARYCARE / DICTATION is the best
# fit for assisted-living caregiver voice notes.
TRANSCRIBE_LANGUAGE_CODE=en-US
TRANSCRIBE_SPECIALTY=PRIMARYCARE
TRANSCRIBE_TYPE=DICTATION

# Poll cadence and total timeout for the Transcribe job. The worker
# blocks on this; pick a TIMEOUT well under SQS_VISIBILITY_TIMEOUT.
# Default: poll every 5s, give up after 5 minutes.
TRANSCRIBE_POLL_INTERVAL_SECONDS=5
TRANSCRIBE_TIMEOUT_SECONDS=300


# -----------------------------------------------------------------------------
# Pipeline behaviour
# -----------------------------------------------------------------------------
# Auto-approve threshold. An update at or above this confidence is
# applied without human review; anything below routes to the human-
# review queue. DO NOT raise this without a signed-off validation
# study — it directly controls how much PHI the LLM can alter
# unsupervised.
CONFIDENCE_THRESHOLD=0.85

# Worker concurrency: number of pipeline runs processed in parallel
# by a single worker container. Also controls the LangGraph
# checkpointer pool sizing (max_pool = WORKER_CONCURRENCY * 2). Raise
# only after confirming DB and Bedrock concurrency headroom.
WORKER_CONCURRENCY=2
